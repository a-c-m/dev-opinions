{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite"],
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "**/*.jsonc"
    ],
    "ignoreUnknown": true
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "rules": {
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "pino-cloudwatch": "Logger transports in app code are banned. Write JSON to stdout; route at infra. See docs/adr/0031-structured-logging-contract.md.",
              "pino-cloudwatch-transport": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "pino-loki": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "pino-datadog": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "pino-sentry": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "pino-elasticsearch": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "pino-mongodb": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "pino-logflare": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "winston-cloudwatch": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "winston-loki": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "winston-datadog": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "winston-sentry": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md.",
              "winston-elasticsearch": "Logger transports in app code are banned. See docs/adr/0031-structured-logging-contract.md."
            }
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/env.ts", "**/env.*.ts"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.config.ts", "**/*.config.js"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      // OTel + pino spec field names (trace_id, span_id, trace_flags, etc.) are
      // snake_case by spec. shared/logger/ and any pino serialisers must keep them.
      "includes": ["**/shared/logger/**", "**/*.logger.ts"],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": [
        "**/e2e/**",
        "**/*.spec.ts",
        "**/*.test.ts",
        "**/*.test.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
