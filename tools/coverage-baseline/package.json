{
  "name": "coverage-baseline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Ratchet test coverage against a committed baseline — fail on drops, allow improvements. Companion to a global coverage policy.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "bin": {
    "coverage-baseline": "./src/cli.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "picomatch": "4.0.2"
  },
  "devDependencies": {
    "@types/picomatch": "4.0.3",
    "@vitest/coverage-v8": "4.1.7",
    "vitest": "4.1.7"
  }
}
