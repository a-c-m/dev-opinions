{
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@nx/eslint": "22.7.4",
    "@nx/js": "22.7.4",
    "@nx/nest": "22.7.4",
    "@nx/playwright": "22.7.4",
    "@nx/react": "22.7.4",
    "@nx/vite": "22.7.4",
    "@playwright/test": "1.60.0",
    "@types/node": "22.19.17",
    "@typescript/native-preview": "7.0.0-dev.20260425.1",
    "@vitest/coverage-v8": "4.1.7",
    "biome-suppressed": "1.3.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "knip": "6.14.2",
    "lefthook": "2.1.8",
    "nx": "22.7.4",
    "pino-pretty": "13.1.3",
    "typescript": "6.0.3",
    "ultracite": "7.8.0",
    "vitest": "4.1.7"
  },
  "name": "dev-opinions",
  "scripts": {
    "scripts:help": "node scripts/help.mjs",
    "prepare": "lefthook install",
    "dev": "nx run-many --target=dev --all --parallel",
    "dev:obs": "podman compose -f docker-compose.observability.yml up -d",
    "dev:obs:down": "podman compose -f docker-compose.observability.yml down",
    "watch-logs": "tail -f .ai-wip/logs/*.log | pino-pretty",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "test:cov": "vitest run --coverage",
    "test:e2e": "nx run-many --target=e2e --all",
    "cov:check": "node tools/coverage-baseline/src/cli.ts check",
    "cov:promote": "node tools/coverage-baseline/src/cli.ts promote",
    "lint": "bs check --write",
    "lint:check": "bs check",
    "lint:ci": "bs check --suppression-fail-on-improvement",
    "lint:init": "bs init",
    "lint:update": "bs update",
    "lint:status": "bs status",
    "lint:clear": "bs clear",
    "typecheck": "nx run-many --target=typecheck --all",
    "knip": "knip",
    "security": "./scripts/security-scan.sh",
    "check:overrides": "node scripts/check-pnpm-overrides.mjs",
    "check:shared": "node scripts/check-shared-conventions.mjs",
    "check": "pnpm lint:check && pnpm typecheck && pnpm test:cov && pnpm cov:check && pnpm knip && pnpm security && pnpm check:overrides && pnpm check:shared",
    "check:fast": "nx run-many --target=lint --all && nx run-many --target=typecheck --all && nx affected --target=test",
    "commit": "cz",
    "release": "nx release",
    "reset": "./scripts/reset-template.sh",
    "fix": "ultracite fix"
  },
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "Alex McFadyen",
  "description": "Opinionated monorepo starter — pnpm + NX + TypeScript strict + Biome/Ultracite + NestJS + React/Vite + Vitest + Playwright + Drizzle + Lefthook + Trivy + OpenTofu. Decisions in docs/adr/.",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.19.0",
    "pnpm": "9.15.9"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "nx",
      "unrs-resolver",
      "@import-meta-env/unplugin"
    ],
    "overrides": {
      "fastify": "5.8.5",
      "fast-uri": "3.1.2",
      "picomatch": "4.0.4"
    }
  }
}
