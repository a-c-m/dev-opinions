{
  "name": "dev-opinions",
  "version": "0.1.0",
  "private": true,
  "description": "Opinionated monorepo starter — pnpm + NX + TypeScript strict + Biome/Ultracite + NestJS + React/Vite + Vitest + Playwright + Drizzle + Lefthook + Trivy + OpenTofu. Decisions in docs/adr/.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "prepare": "lefthook install",
    "dev": "nx run-many --target=dev --all --parallel",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "test:e2e": "nx run-many --target=e2e --all",
    "lint": "bs check --write",
    "lint:check": "bs check",
    "lint:ci": "bs check --suppression-fail-on-improvement",
    "lint:init": "bs init",
    "lint:update": "bs update",
    "lint:status": "bs status",
    "lint:clear": "bs clear",
    "typecheck": "nx run-many --target=typecheck --all",
    "knip": "knip",
    "security": "./scripts/security-scan.sh",
    "check": "pnpm lint:check && pnpm typecheck && pnpm test && pnpm knip && pnpm security",
    "check:affected": "nx affected --target=lint,typecheck,test",
    "commit": "cz",
    "release": "nx release",
    "reset": "./scripts/reset-template.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "@nx/eslint": "22.7.0",
    "@nx/js": "22.7.0",
    "@nx/nest": "22.7.0",
    "@nx/playwright": "22.7.0",
    "@nx/react": "22.7.0",
    "@nx/vite": "22.7.0",
    "@playwright/test": "1.59.1",
    "@types/node": "22.19.17",
    "@typescript/native-preview": "7.0.0-dev.20260425.1",
    "biome-suppressed": "1.3.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "knip": "6.7.0",
    "lefthook": "2.1.6",
    "nx": "22.7.0",
    "typescript": "6.0.3",
    "ultracite": "5.4.5",
    "vitest": "4.1.5"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "pnpm": {
    "overrides": {
      "fastify": "5.8.5"
    }
  }
}
