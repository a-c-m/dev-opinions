{
  "name": "sample-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/sample/web/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": { "script": "build" }
    },
    "dev": {
      "executor": "nx:run-script",
      "options": { "script": "dev" }
    },
    "test": {
      "executor": "nx:run-script",
      "options": { "script": "test" }
    },
    "e2e": {
      "executor": "nx:run-script",
      "options": { "script": "e2e" }
    },
    "typecheck": {
      "executor": "nx:run-script",
      "options": { "script": "typecheck" }
    },
    "lint": {
      "executor": "nx:run-script",
      "options": { "script": "lint" }
    }
  },
  "tags": ["scope:sample", "type:app"]
}
