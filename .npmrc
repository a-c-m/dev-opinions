# Supply-chain cooldown per Priya F-2 / ADR 0008.
#
# Refuses to install packages published within the last 36 hours. Structural
# mitigation against the Shai-Hulud / TanStack Mini Shai-Hulud / s1ngularity
# attack class — those compromised packages were all yanked from npm within
# ~12h of detection. 36h gives community-detection headroom without blocking
# legitimate security patches for more than a quarter-day.
#
# pnpm 11 turns this on by default at 24h; we're on pnpm 9 + 36h here.
# When a CVE patch truly cannot wait, add the package to
# `minimumReleaseAgeExclude` in pnpm.<workspace>.config (or pnpm-workspace.yaml).
minimum-release-age=2160

# Lockfile + reproducibility hygiene.
save-exact=true
save-workspace-protocol=rolling
