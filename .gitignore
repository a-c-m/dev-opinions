node_modules/
.pnpm-store/
dist/
build/
**/coverage/*
!/coverage/.gitkeep
**/.nx/*
!/.nx/.gitkeep
.next/
.turbo/
.cache/

# env
.env
.env.local
.env.*.local
!.env.example

# direnv — local shell env loaded on `cd` into the repo. `.envrc.example` is
# committed as the template; the real `.envrc` is per-developer.
.envrc
!.envrc.example

# editor / OS
.DS_Store
*.swp
.idea/
.vscode/
!.vscode/settings.json.example

# playwright
test-results/
playwright-report/
blob-report/
playwright/.cache/
.playwright-mcp/

# beads — local task manager, wired via .claude/skills/beads-local-tasks.md
# State is intentionally local-only (user convention); team tasks live on GitHub Issues.
.beads/

# Claude Code runtime cruft (session state, not template content).
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Scratch logs / WIP captures from Bash tool calls. CLAUDE.md "Capture output
# for review" — one known location, survives across sessions. Contents are
# never committed; .gitkeep is tracked so the dir is present on fresh clones
# (hooks and scripts write here without first checking the dir exists).
**/.ai-wip/*
!/.ai-wip/.gitkeep

# "Wrap an existing setup" mode — checkouts of other repos that agent sessions
# can see for ADR-context purposes. Those repos own their own history; this
# repo just hosts them as siblings. See README "Wrapping an existing setup".
repos/

# misc
*.log
*.tsbuildinfo
