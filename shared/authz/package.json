{
  "name": "@shared/authz",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "projectType": "library",
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    },
    "tags": [
      "scope:shared",
      "type:lib"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "bs check --write .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@casl/ability": "6.7.5",
    "@shared/auth": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@vitest/coverage-v8": "4.1.5",
    "vitest": "4.1.5"
  }
}
