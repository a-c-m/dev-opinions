{
  "name": "@shared/flags",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "projectType": "library",
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    },
    "tags": [
      "scope:shared",
      "type:lib"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "bs check --write .",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  }
}
