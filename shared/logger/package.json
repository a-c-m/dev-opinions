{
  "name": "@shared/logger",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./base-options": {
      "types": "./dist/base-options.d.ts",
      "default": "./dist/base-options.js"
    },
    "./nest": {
      "types": "./dist/nest.module.d.ts",
      "default": "./dist/nest.module.js"
    }
  },
  "nx": {
    "projectType": "library",
    "targets": {
      "build": {
        "outputs": [
          "{projectRoot}/dist"
        ]
      }
    },
    "tags": [
      "scope:shared",
      "type:lib"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsgo --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "11.1.19",
    "@vitest/coverage-v8": "4.1.5",
    "vitest": "4.1.5"
  }
}
