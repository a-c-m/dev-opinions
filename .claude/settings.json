{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm remove:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm test:e2e:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm knip:*)",
      "Bash(pnpm check:*)",
      "Bash(pnpm commit:*)",
      "Bash(pnpm security:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm view:*)",
      "Bash(pnpm help:*)",
      "Bash(pnpm scripts:help:*)",
      "Bash(pnpm nx:*)",
      "Bash(pnpm --version)",
      "Bash(corepack enable:*)",
      "Bash(nx:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git --no-pager diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git remote -v)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(./.claude/commands/check.sh)",
      "Bash(./.claude/commands/create-issue.sh:*)",
      "Bash(./.claude/commands/create-pr.sh:*)",
      "Bash(mkdir -p .ai-wip)",
      "Bash(./scripts/setup-mac.sh:*)",
      "Bash(bd:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(node .ai-wip/*)",
      "Bash(cd repos/*)",
      "Bash(cd ./repos/*)",
      "Bash(echo \"exit=$?\")",
      "Bash(echo \"$?\")",
      "Bash(git remote:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_close"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(sudo:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(wget * | bash:*)",
      "Bash(npm install -g:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --force-if-includes:*)",
      "Bash(git push -f:*)",
      "Bash(git push -u --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout .:*)",
      "Bash(git checkout -- .:*)",
      "Bash(git restore .:*)",
      "Bash(git restore -- .:*)",
      "Bash(git branch -d:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch --delete:*)",
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Grep"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-edit-biome.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-edit-no-wait.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/block-bash-git.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/block-bash-biome.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/block-bash-rules.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/allow-bash-capture.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/notify-edit-biome.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/notify-bash-commit.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/bootstrap-session-beads.sh\""
          }
        ]
      }
    ]
  }
}
