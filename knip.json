{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/**/*.{js,ts,sh}"]
    },
    "apps/sample/api": {
      "entry": ["src/main.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/sample/web": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/sample/web-e2e": {
      "entry": ["e2e/**/*.spec.ts", "playwright.config.ts"],
      "project": ["e2e/**/*.ts", "playwright.config.ts"]
    },
    "shared/logger": {
      "entry": ["src/types.ts", "src/base-options.ts", "src/nest.module.ts"],
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "@nx/eslint",
    "@nx/js",
    "@nx/nest",
    "@nx/playwright",
    "@nx/react",
    "@nx/vite",
    "@playwright/test"
  ],
  "ignoreBinaries": ["podman", "tail"],
  "ignoreExportsUsedInFile": true
}
